# 运行环境：development / staging / production
APP_ENV=development
# API 服务监听地址
API_ADDRESS=:8080
# Worker 轮询任务间隔
WORKER_POLL_INTERVAL=5s
# 实时网关监听地址
REALTIME_ADDRESS=:8081
# PostgreSQL 连接串
POSTGRES_DSN=postgres://blockbeast:blockbeast@postgres:5432/blockbeast?sslmode=disable
# Redis 地址（当前功能按需使用）
REDIS_ADDRESS=redis:6379
# NATS JetStream 地址
NATS_URL=nats://nats:4222
# JWT 签名密钥。生产环境必须替换为随机高强度字符串，不能提交到 Git。
AUTH_TOKEN_SECRET=dev-only-signing-secret-change-me-in-production-0123456789abcdef
# JWT 访问令牌有效期
ACCESS_TOKEN_TTL=15m
# Webhook 时间戳允许偏差，防止重放攻击；回调验签使用 PQPA_API_SECRET
CHAIN_WEBHOOK_ALLOWED_SKEW=5m
# PQPA API 基础地址（请以 PQPA 商户后台或官方文档提供的地址为准）
PQPA_API_URL=https://api.pqpa.com
# PQPA 商户 API Key；不要写入代码或提交到 Git
PQPA_API_KEY=replace-with-sandbox-key
# PQPA 商户 API Secret；不要写入代码或提交到 Git
PQPA_API_SECRET=replace-with-sandbox-secret
# PQPA 链和代币代码，请按商户后台实际启用配置调整
PQPA_CHAIN_CODE=TRON
PQPA_TOKEN_CODE=USDT
# PQPA 支持资产缓存刷新间隔
PQPA_ASSET_SYNC_INTERVAL=1h
